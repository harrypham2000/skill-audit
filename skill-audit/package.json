{
  "name": "@hungpg/skill-audit",
  "version": "0.8.0",
  "description": "Security auditing CLI for AI agent skills with PII detection and compliance validation",
  "type": "module",
  "bin": {
    "skill-audit": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "postinstall": "node scripts/postinstall.cjs",
    "security:update": "node dist/index.js --update-db",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "scripts",
    "references",
    "examples",
    "rules",
    "README.md",
    "SKILL.md"
  ],
  "keywords": [
    "security",
    "audit",
    "cli",
    "ai",
    "agent",
    "skills",
    "vulnerability",
    "owasp",
    "prompt-injection",
    "llm-security"
  ],
  "author": "Hung Pham",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harrypham2000/skill-audit.git"
  },
  "bugs": {
    "url": "https://github.com/harrypham2000/skill-audit/issues"
  },
  "homepage": "https://github.com/harrypham2000/skill-audit#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  }
}
